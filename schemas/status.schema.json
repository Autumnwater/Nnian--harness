{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hexai.dev/harness/status.schema.json",
  "title": "Harness Run Status",
  "description": "Machine-readable status for a Harness task run",
  "type": "object",
  "required": ["schemaVersion", "stateRevision", "stageRevision", "execution", "taskId", "taskTitle", "createdAt", "updatedAt", "currentSubtask", "currentStage", "subtasks", "history"],
  "properties": {
    "schemaVersion": {
      "const": 4,
      "description": "Internal status.json storage schema version"
    },
    "stateRevision": {
      "type": "integer",
      "minimum": 0,
      "description": "Monotonic revision incremented by every persisted mutation"
    },
    "stageRevision": {
      "type": "integer",
      "minimum": 0,
      "description": "Workflow cursor and gate-evidence revision used by stage CAS"
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "activeJobId", "activeAttemptId", "activeLeaseToken", "lockEpoch", "lastJobId"],
      "properties": {
        "mode": { "type": "string", "enum": ["manual", "worker"] },
        "activeJobId": { "type": ["string", "null"] },
        "activeAttemptId": { "type": ["string", "null"] },
        "activeLeaseToken": { "type": ["string", "null"] },
        "lockEpoch": { "type": "integer", "minimum": 0 },
        "lastJobId": { "type": ["string", "null"] }
      }
    },
    "taskId": {
      "type": "string",
      "description": "Task identifier, e.g. W6-A"
    },
    "taskTitle": {
      "type": "string",
      "description": "Human-readable task title"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "currentSubtask": {
      "type": "string",
      "description": "Current subtask ID, e.g. W6-A-02"
    },
    "currentStage": {
      "type": "string",
      "description": "Current stage, e.g. implementation-plan"
    },
    "residualRisks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "subtask": { "type": "string" },
          "stage": { "type": "string" },
          "risk": { "type": "string" },
          "recordedAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "subtasks": {
      "type": "object",
      "patternProperties": {
        "^W6-A-\\d{2}$": {
          "type": "object",
          "required": ["id", "title", "shortTitle", "taskTheme", "status", "stages"],
          "properties": {
            "id": { "type": "string" },
            "title": { "type": "string" },
            "shortTitle": { "type": "string" },
            "taskTheme": { "type": "string" },
            "status": {
              "type": "string",
              "enum": ["pending", "active", "completed", "blocked", "skipped", "imported-completed"]
            },
            "stages": {
              "type": "object",
              "patternProperties": {
                ".*": {
                  "type": "object",
                  "required": ["stageStatus"],
                  "properties": {
                    "stageStatus": {
                      "type": "string",
                      "enum": ["pending", "active", "interrupted", "completed", "blocked", "skipped", "imported-completed", "assumed-completed"]
                    },
                    "primaryReportPath": { "type": "string" },
                    "mirrorOutputPath": { "type": "string" },
                    "handoffPath": { "type": "string" },
                    "mirrorHandoffPath": { "type": "string" },
                    "startedAt": { "type": "string", "format": "date-time" },
                    "completedAt": { "type": "string", "format": "date-time" },
                    "interruptReason": { "type": "string" },
                    "expectedHandoffPath": { "type": "string" },
                    "openFindings": {
                      "type": "object",
                      "properties": {
                        "P0": { "type": "integer", "default": 0 },
                        "P1": { "type": "integer", "default": 0 },
                        "P2": { "type": "integer", "default": 0 }
                      }
                    },
                    "residualRisk": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timestamp", "action"],
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "action": { "type": "string" },
          "details": { "type": "object" }
        }
      }
    }
  }
}
