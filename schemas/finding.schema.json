{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hexai.dev/harness/finding.schema.json",
  "title": "Review Finding",
  "description": "Structured review finding (P0/P1/P2) in Markdown outputs",
  "type": "object",
  "required": ["id", "priority", "status", "owner", "module", "issue", "expected"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Finding ID, e.g. W6-A-01-P1-001",
      "pattern": "^W6-A-\\d{2}-P[012]-\\d{3}$"
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2"],
      "description": "P0=blocker, P1=high, P2=medium"
    },
    "status": {
      "type": "string",
      "enum": ["open", "fixed", "accepted", "deferred", "wont-fix"],
      "description": "Current status of the finding"
    },
    "owner": {
      "type": "string",
      "description": "Profile responsible for resolution",
      "enum": ["claude-implementer-minimax", "claude-reviewer-deepseek", "codex-overall-reviewer"]
    },
    "module": {
      "type": "string",
      "description": "Affected module name"
    },
    "files": {
      "type": "array",
      "description": "Affected file paths",
      "items": { "type": "string" }
    },
    "issue": {
      "type": "string",
      "description": "Description of the issue"
    },
    "expected": {
      "type": "string",
      "description": "Expected behavior or fix"
    },
    "acceptance": {
      "type": "string",
      "description": "Acceptance criteria for the fix"
    },
    "fixMapping": {
      "type": "object",
      "description": "Fix mapping for resolved findings",
      "properties": {
        "finding": { "type": "string" },
        "status": { "type": "string" },
        "fixFile": { "type": "string" },
        "verification": { "type": "string" }
      }
    }
  }
}
